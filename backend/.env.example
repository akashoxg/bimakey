# ==============================================
# BimaKey Backend - Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
# Get free cluster at: https://www.mongodb.com/atlas
MONGO_URI=mongodb://127.0.0.1:27017/insure-right

# Email (SMTP) - Use Gmail App Password or your email service
# Gmail: https://myaccount.google.com/security -> App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Form submissions will be sent to this email
NOTIFICATION_EMAIL=Jitendrapoc@gmail.com
ADMIN_EMAIL=hello@bimakey.in

# WhatsApp Notification
# Set to true to enable WhatsApp click-to-chat links
WHATSAPP_ENABLED=false
# Admin WhatsApp number (without +91)
WHATSAPP_ADMIN_NUMBER=919876543210

# JWT for Admin Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
# Max lead submissions per IP per window
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=5
